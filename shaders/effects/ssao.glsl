#ifndef FX_SSAO
#define FX_SSAO

#include "/effects/options.glsl"

#define SSAO_INV_SAMPLES -0.5/SSAO_SAMPLES

float ssao_rand(vec2 co)
{
    return fract((dot(co.xy ,vec2(12.9898,78.233))) * 43758.5453);
}

vec3 ssao_get_viewspace_position(vec2 texcoord, float depth, mat4x4 projection_mat_inverse) {
    vec3 clipSpace = vec3(texcoord, depth) * 2.0 - 1.0;
    vec4 viewW = projection_mat_inverse * vec4(clipSpace, 1.0);
    return viewW.xyz / viewW.w;
}

struct SSAOMats {
    mat4 model_view;
    mat4 model_view_inverse;
    mat4 projection;
    mat4 projection_inverse;
};

